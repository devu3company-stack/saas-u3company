  pm2 start server.js --name ${instancia_add}-frontend
  pm2 save --force
  pm2 startup
  env PATH=\$PATH:/usr/bin /usr/lib/node_modules/pm2/bin/pm2 startup systemd -u deploy --hp /home/deploy
EOF

  log_success "Frontend iniciado"
  sleep 2
}

frontend_nginx_setup() {
  print_banner
  log_info "Configurando Nginx (frontend)..."
  sleep 2

  frontend_hostname=$(echo "${frontend_url}" | sed 's|https://||')

  sudo su - root <<EOF
  cat > /etc/nginx/sites-available/${instancia_add}-frontend << 'END'
server {
  server_name ${frontend_hostname};
  location / {
    proxy_pass http://127.0.0.1:${frontend_port};
    proxy_http_version 1.1;
    proxy_set_header Upgrade \$http_upgrade;
    proxy_set_header Connection 'upgrade';
    proxy_set_header Host \$host;
    proxy_set_header X-Real-IP \$remote_addr;
    proxy_set_header X-Forwarded-Proto \$scheme;
    proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
    proxy_cache_bypass \$http_upgrade;
  }
}
END
  ln -sf /etc/nginx/sites-available/${instancia_add}-frontend /etc/nginx/sites-enabled/
EOF

  log_success "Nginx configurado (frontend)"
  sleep 2
}

