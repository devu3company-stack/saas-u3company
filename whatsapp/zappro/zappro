frontend_node_build() {
  print_banner
  log_info "Compilando frontend..."
  sleep 2

  swap_mem=$(free -m | awk 'NR==3{printf "%.0f", $2}')
  total_mem=$(free -m | awk 'NR==2{printf "%.0f", $2}')
  
  if [ "$swap_mem" -eq 0 ] && [ "$total_mem" -lt 8192 ]; then
    log_warning "Configurando swap para evitar travamento..."
    sudo fallocate -l 6G /swapfile 2>/dev/null || true
    sudo chmod 600 /swapfile 2>/dev/null || true
    sudo mkswap /swapfile 2>/dev/null || true
    sudo swapon /swapfile 2>/dev/null || true
    echo '/swapfile none swap sw 0 0' | sudo tee -a /etc/fstab >/dev/null || true
    log_success "Swap configurado"
  fi

  log_info "Liberando memória para build..."
  sudo systemctl stop apache2 2>/dev/null || true
  sudo systemctl stop mysql 2>/dev/null || true
  sudo sync && sudo sysctl vm.drop_caches=3 2>/dev/null || true

  sudo su - deploy <<EOF
  cd /home/deploy/${instancia_add}/frontend
  rm -rf build node_modules/.cache .eslintcache
  
  NODE_OPTIONS="--max-old-space-size=1536 --openssl-legacy-provider" \
  GENERATE_SOURCEMAP=false \
  INLINE_RUNTIME_CHUNK=false \
  IMAGE_INLINE_SIZE_LIMIT=0 \
  ESLint_NO_DEV_ERRORS=true \
  FAST_REFRESH=false \
  CI=true \
  DISABLE_ESLINT_PLUGIN=true \
  TSC_COMPILE_ON_ERROR=true \
  npm run build --silent 2>/dev/null || npm run build 2>&1 | grep -v "WARNING\|warning\|deprecated" || true
EOF

  build_exit_code=$?

  sudo systemctl start nginx 2>/dev/null || true
  sudo systemctl start mysql 2>/dev/null || true

  if [ $build_exit_code -ne 0 ]; then
    log_error "Build falhou"
    exit 1
  fi

  log_success "Frontend compilado"
  sleep 2
}

frontend_start_pm2() {
  print_banner
