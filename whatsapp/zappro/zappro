deletar_tudo() {
  print_banner
  log_warning "Deletando instância ${empresa_delete}..."
  sleep 2

  sudo su - root <<EOF
  export DEBIAN_FRONTEND=noninteractive
  docker container rm redis-${empresa_delete} --force 2>/dev/null || true
  rm -rf /etc/nginx/sites-enabled/${empresa_delete}-frontend
  rm -rf /etc/nginx/sites-enabled/${empresa_delete}-backend  
  rm -rf /etc/nginx/sites-available/${empresa_delete}-frontend
  rm -rf /etc/nginx/sites-available/${empresa_delete}-backend
EOF

  sudo -u postgres bash <<EOSQL
  dropuser ${empresa_delete} 2>/dev/null || true
  dropdb ${empresa_delete} 2>/dev/null || true
EOSQL

  sudo su - deploy <<EOF
  rm -rf /home/deploy/${empresa_delete}
  pm2 delete ${empresa_delete}-frontend ${empresa_delete}-backend 2>/dev/null || true
  pm2 save
EOF

  log_success "Instância ${empresa_delete} removida"
  sleep 2
}

