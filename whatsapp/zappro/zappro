configurar_dominio() {
  print_banner
  log_info "Alterando domínios da instância ${empresa_dominio}..."
  sleep 2

  sudo su - root <<EOF
  export DEBIAN_FRONTEND=noninteractive
  rm -rf /etc/nginx/sites-enabled/${empresa_dominio}-frontend
  rm -rf /etc/nginx/sites-enabled/${empresa_dominio}-backend  
  rm -rf /etc/nginx/sites-available/${empresa_dominio}-frontend
  rm -rf /etc/nginx/sites-available/${empresa_dominio}-backend
EOF

  sudo su - deploy <<EOF
  cd /home/deploy/${empresa_dominio}/frontend
  sed -i "1c\REACT_APP_BACKEND_URL=https://${alter_backend_url}" .env
  cd /home/deploy/${empresa_dominio}/backend
  sed -i "2c\BACKEND_URL=https://${alter_backend_url}" .env
  sed -i "3c\FRONTEND_URL=https://${alter_frontend_url}" .env 
EOF

  backend_hostname=$(echo "${alter_backend_url}" | sed 's|https://||')

  sudo su - root <<EOF
  export DEBIAN_FRONTEND=noninteractive
  cat > /etc/nginx/sites-available/${empresa_dominio}-backend << 'END'
server {
  server_name ${backend_hostname};
  location / {
    proxy_pass http://127.0.0.1:${alter_backend_port};
    proxy_http_version 1.1;
    proxy_set_header Upgrade \$http_upgrade;
    proxy_set_header Connection 'upgrade';
    proxy_set_header Host \$host;
    proxy_set_header X-Real-IP \$remote_addr;
    proxy_set_header X-Forwarded-Proto \$scheme;
    proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
    proxy_cache_bypass \$http_upgrade;
  }
}
END
  ln -s /etc/nginx/sites-available/${empresa_dominio}-backend /etc/nginx/sites-enabled
EOF

  frontend_hostname=$(echo "${alter_frontend_url}" | sed 's|https://||')

  sudo su - root <<EOF
  export DEBIAN_FRONTEND=noninteractive
  cat > /etc/nginx/sites-available/${empresa_dominio}-frontend << 'END'
server {
  server_name ${frontend_hostname};
  location / {
    proxy_pass http://127.0.0.1:${alter_frontend_port};
    proxy_http_version 1.1;
    proxy_set_header Upgrade \$http_upgrade;
    proxy_set_header Connection 'upgrade';
    proxy_set_header Host \$host;
    proxy_set_header X-Real-IP \$remote_addr;
    proxy_set_header X-Forwarded-Proto \$scheme;
    proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
    proxy_cache_bypass \$http_upgrade;
  }
}
END
  ln -s /etc/nginx/sites-available/${empresa_dominio}-frontend /etc/nginx/sites-enabled
EOF

  sudo systemctl restart nginx

  backend_domain=$(echo "${alter_backend_url}" | sed 's|https://||')
  frontend_domain=$(echo "${alter_frontend_url}" | sed 's|https://||')

  sudo certbot -m "${DEPLOY_EMAIL}" \
    --nginx \
    --agree-tos \
    --non-interactive \
    --domains "${backend_domain},${frontend_domain}"

  log_success "Domínios alterados para ${empresa_dominio}"
  sleep 2
}

