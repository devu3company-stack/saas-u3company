backend_redis_create() {
  print_banner
  log_info "Criando Redis e Banco PostgreSQL..."
  sleep 2

  if [ -z "${redis_port}" ] || [ -z "${redis_pass}" ] || [ -z "${instancia_add}" ]; then
    log_error "Variáveis Redis não definidas!"
    exit 1
  fi

  sudo su - root <<EOF
  usermod -aG docker deploy
  docker run --name redis-${instancia_add} \
    -p ${redis_port}:6379 \
    --restart always \
    --detach redis \
    redis-server --requirepass ${redis_pass}
EOF

  sleep 5

  if ! docker ps | grep -q "redis-${instancia_add}"; then
    log_error "Redis não iniciou"
    docker logs "redis-${instancia_add}" 2>/dev/null || true
    exit 1
  fi

  log_success "Redis rodando na porta ${redis_port}"

  sudo -u postgres bash <<EOSQL
    createdb ${instancia_add};
    psql -c "CREATE USER ${instancia_add} WITH SUPERUSER PASSWORD '${DB_PASS}';"
EOSQL

  log_success "Banco PostgreSQL criado"
  sleep 2
}

