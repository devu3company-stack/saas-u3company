system_configure_noninteractive() {
  print_banner
  log_info "Configurando modo não-interativo..."
  sleep 2

  sudo su - root <<'EOF'
  export DEBIAN_FRONTEND=noninteractive
  export NEEDRESTART_MODE=a
  export NEEDRESTART_SUSPEND=1
  
  echo 'libc6 libraries/restart-without-asking boolean true' | debconf-set-selections
  echo 'libssl1.1:amd64 libraries/restart-without-asking boolean true' | debconf-set-selections
  echo 'libssl3:amd64 libraries/restart-without-asking boolean true' | debconf-set-selections
  
  mkdir -p /etc/needrestart/conf.d/
  echo "\$nrconf{restart} = 'a';" > /etc/needrestart/conf.d/50local.conf
  
  dpkg --configure -a
EOF

  log_success "Modo não-interativo configurado"
  sleep 2
}

